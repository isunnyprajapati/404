<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>404</title>
    <link rel="stylesheet" href="styles/main.css">
    <link rel="stylesheet" href="styles/header.css">
    <link rel="stylesheet" href="styles/home.css">


</head>

<body>
    <!-- Header -->
    <section class="main-head">
        <div class="header">
            <div class="title">
                <span>404</span>
            </div>
            <div class="nav-btns">
                <a class="nav-btn <%= page === 'home'? 'active' : '' %>" id="home" href="/">Home</a>
                <a class="nav-btn <%= page === 'about'? 'active' : '' %>" id="about" href="/about">Journal</a>
                <a class="nav-btn <%= page === 'links'? 'active' : '' %>" id="links" href="/links">Blog</a>
            </div>
            <div class="search-bar">
                <form action="/search">
                    <input class="search-box" type="text" placeholder="Search">
                    <svg id="search-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                        class="bi bi-search" viewBox="0 0 16 16">
                        <path
                            d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0" />
                    </svg>
                </form>
                <svg id="login" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                    fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"></path>
                    <polyline points="10 17 15 12 10 7"></polyline>
                    <line x1="15" y1="12" x2="3" y2="12"></line>
                </svg>

            </div>
        </div>
    </section>